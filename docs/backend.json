
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "desc": { "type": "string" },
        "img": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "github": { "type": "string" }
      },
      "required": ["title", "category", "desc"]
    },
    "Experience": {
      "title": "Experience",
      "description": "A work history item",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "desc": { "type": "string" }
      },
      "required": ["company", "role", "period"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects collection"
    },
    "/experiences/{experienceId}": {
      "schema": "Experience",
      "description": "Work history collection"
    }
  }
}
